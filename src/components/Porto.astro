---
import '../components/porto.css'
import Navbar from '../components/Navbar.jsx'
import {Image} from 'astro:assets'
import {profile} from '../data/Profile';
import {experiences} from '../data/Experiences';
import {portfolios} from '../data/Portopolio';
import {techStacks} from '../data/TechStacks';
import {certificates} from '../data/Certificates';

---


<main class="portofolio">
    <Navbar client:load/>


    <header id="home" class="fade-up hero card reveal delay-1">
        <div>
            <!--<h1>{profile.title} | {profile.name}</h1>-->
            <h1>{profile.name} | {profile.title}</h1>
            <p class="description">{profile.description}</p>
            <div class="social-buttons">
                <a href="https://github.com/lana-jo" target="_blank" rel="noopener" class="social-icon-btn"
                   title="GitHub">
                    <img src="/github.svg" alt="https://github.com/lana-jo"/>
                </a>

                <a href="https://www.linkedin.com/in/lana-jauhar-75604317a/" target="_blank" rel="noopener"
                   class="social-icon-btn" title="LinkedIn">
                    <!-- LinkedIn Icon -->
                    <img src="/linkedin.svg" alt="https://www.linkedin.com/in/lana-jauhar-75604317a/"/>
                </a>

                <a href="mailto:lanajauhar06@gmail.com" class="social-icon-btn" title="Email Me">
                    <img src="/mail.svg" alt="lanajauhr06@gmail.com"/>
                </a>
            </div>

        </div>
        <Image class="profile-photo" src={profile.photo} alt={profile.name}/>
        <!--<img class="profile-photo" src={profile.photo} alt={`Foto profil ${profile.name}`} loading="eager"/>-->
    </header>

    <!--<section id="aboutme" class="card reveal delay-2">
        <h2>About Me</h2>
        <p>
            Saya memiliki pengalaman <strong>1 tahun sebagai developer</strong> dan <strong>2 tahun
            sebagai guru</strong>, sehingga saya bisa memadukan keduanya untuk mewujudkan keinginan
            Anda secara teknis sekaligus komunikatif.
        </p>
    </section>-->


    <section id="experience" class="fade-up card reveal delay-2">
        <h2>Experience</h2>

        <div class="timeline">
            {
                experiences.map((item) => (
                        <div class="timeline-item">
                            <div class="timeline-content">
                                <h3>{item.role}</h3>
                                <small>{item.period}</small>
                                <h4>{item.company}</h4>

                                <ul>
                                    {item.descriptions.map((desc) => (
                                            <li>{desc}</li>
                                    ))}
                                </ul>
                            </div>
                        </div>
                ))
            }
        </div>
    </section>

    <section id="techstack" class="fade-up card reveal delay-2">
        <h2>Tech Stack</h2>
        <div class="chips">
            {
                techStacks.map((stack) => (
                        <span class="chip">{stack}</span>
                ))
            }
        </div>
    </section>

    <section id="project" class="fade-up card reveal delay-4">
        <div class="porto-header">
            <h2>Project</h2>
            <a href="https://github.com/lana-jo" target="_blank" class="view-all-btn">
                View All
            </a>
        </div>

        <div class="projects">
            {
                portfolios.map((item) => (
                        <article class="project-item">
                            <h3>{item.title}</h3>
                            <p>{item.detail}</p>
                            <small>{item.stack}</small>
                            <br/>
                            <a href={item.github} target="_blank">
                                <button class="porto-btn">View Project</button>
                            </a>
                        </article>
                ))
            }
        </div>
    </section>

    <section id="certif" class="card reveal delay-2">
        <h2>Certificate</h2>

        <div>
            {
                certificates.map((item) => (
                        <div class="certificate-item">
                            <h3>{item.name}</h3>

                            {Array.isArray(item.photo) ? (
                                item.photo.map((img) => (
                                        <Image src={img} alt={item.name}/>
                                ))
                            ) : (
                                    <Image src={item.photo} alt={item.name}/>
                            )}

                        </div>
                ))
            }
        </div>
    </section>

    <section id="contact" class="fade-up card reveal delay-4">
        <div class="flex flex-col space-y-2">
            <!--<h1>{profile.title} | {profile.name}</h1>-->
            <h1>Let Contact with me</h1>
            <div class="contact-buttons">
                <a href="https://github.com/lana-jo" target="_blank" rel="noopener" class="contact-icon-btn"
                   title="GitHub">
                    <img src="/github.svg" alt="https://github.com/lana-jo"/>
                </a>

                <a href="https://www.linkedin.com/in/lana-jauhar-75604317a/" target="_blank" rel="noopener"
                   class="contact-icon-btn" title="LinkedIn">
                    <!-- LinkedIn Icon -->
                    <img src="/linkedin.svg" alt="https://www.linkedin.com/in/lana-jauhar-75604317a/"/>
                </a>

                <a href="mailto:lanajauhar06@gmail.com" class="contact-icon-btn" title="Email Me">
                    <img src="/mail.svg" alt="lanajauhr06@gmail.com"/>
                </a>
            </div>

        </div>
    </section>

    <script>
        import {gsap} from "gsap";
        import {ScrollTrigger} from "gsap/ScrollTrigger";

        // Register the plugin (required!)
        gsap.registerPlugin(ScrollTrigger);
        const reveals = document.querySelectorAll('.reveal');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }
            });
        }, {
            threshold: 0.2
        });


        reveals.forEach((eL) => observer.observe(eL));

        document.addEventListener("astro:page-load", () => {
            // Option 1: Use the generic (safest with strict TS)
            gsap.utils.toArray<HTMLElement>(".fade-up").forEach((el) => {
                gsap.fromTo(
                    el,
                    {opacity: 0, y: 100},
                    {
                        opacity: 1,
                        y: 0,
                        duration: 0.8,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: el,
                            start: "top 85%",
                            toggleActions: "play none none reverse",
                        },
                    }
                );
            });

            // Option 2: If you want to animate the existing "reveal" cards instead:
            // gsap.utils.toArray<HTMLElement>(".reveal").forEach((el) => { ... });
        });
    </script>

</main>