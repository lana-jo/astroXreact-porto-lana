---
import { ViewTransitions } from 'astro:transitions';
// import Navbar from "../components/Navbar";
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Portofolio Pribadi',
	description = 'Web portofolio modern dengan animasi'
} = Astro.props;
---
<!doctype html>
<html lang="id">
<head>
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width" />
	<link rel="icon" type="image/svg+xml" href="/profile.svg" />
	<link rel="icon" href="/lana.svg" />
	<meta name="generator" content={Astro.generator} />
	<meta name="description" content={description} />
	<title>{title}</title>
</head>
<body><!--
<div class="container">
	<section id="home" data-theme="dark">...</section>
	<section id="about" data-theme="light">...</section>
	<section id="projects" data-theme="dark">...</section>
	<section id="github" data-theme="light">...</section>
	<section id="contact" data-theme="dark">...</section>
</div> -->

<div class="bg-blur bg-blur-one"></div>
<div class="bg-blur bg-blur-two"></div>

<slot />
<ViewTransitions />
</body>
</html>

<style>
	:root {
		font-family: 'Inter', 'Segoe UI', Roboto, system-ui, -apple-system, sans-serif;
		color-scheme: dark;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background: #070b16;
		color: #e8eeff;
	}
</style>
<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	// Register once
	gsap.registerPlugin(ScrollTrigger);

	// Fix ScrollTrigger after Astro View Transitions
	const refreshScrollTrigger = () => {
		ScrollTrigger.refresh();
	};

	document.addEventListener("astro:page-load", refreshScrollTrigger);
	document.addEventListener("astro:after-swap", refreshScrollTrigger);
</script>