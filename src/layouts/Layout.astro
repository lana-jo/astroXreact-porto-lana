---
import { ViewTransitions } from 'astro:transitions';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Portofolio Pribadi',
	description = 'Web portofolio modern dengan animasi'
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="description" content={description} />
	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:image" content="img.png" />
	<meta property="og:image:type" content="image/png" />
	<meta name="generator" content={Astro.generator} />
	<link rel="icon" type="image/svg+xml" href="/lana.svg" />
	<title>{title}</title>
</head>
<body>
	<slot />

	<footer class="footer">
		<div class="footer-content">
			<p class="footer-copyright">&copy; <span id="year"></span> Lana Jauhar. All rights reserved.</p>
			<div class="footer-social">
				<a href="https://github.com/lana-jo" target="_blank" rel="noopener" class="social-icon-btn" title="GitHub">
					<img src="/github.svg" alt="GitHub" />
				</a>
				<a href="https://www.linkedin.com/in/lana-jauhar-75604317a/" target="_blank" rel="noopener" class="social-icon-btn" title="LinkedIn">
					<img src="/linkedin.svg" alt="LinkedIn" />
				</a>
				<a href="https://t.me/j0_here" target="_blank" rel="noopener" class="social-icon-btn" title="Telegram">
					<img src="/telegram.svg" alt="Telegram" />
				</a>
				<a href="mailto:lanajauhar06@gmail.com" class="social-icon-btn" title="Email Me">
					<img src="/mail.svg" alt="Email" />
				</a>
			</div>
		</div>
	</footer>

	<ViewTransitions />
</body>
</html>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

	:root {
		font-family: 'Inter', system-ui, -apple-system, sans-serif;
		color-scheme: light;

		--bg-primary: #fafafa;
		--bg-secondary: #f0f0f0;
		--card-bg: #ffffff;
		--text-primary: #111111;
		--text-secondary: #666666;
		--border-color: #e5e5e5;
		--accent: #2563eb;
	}

	[data-theme="dark"] {
		color-scheme: dark;
		--bg-primary: #0a0a0a;
		--bg-secondary: #171717;
		--card-bg: #141414;
		--text-primary: #ededed;
		--text-secondary: #888888;
		--border-color: #262626;
		--accent: #60a5fa;
	}

	[data-theme="light"] {
		color-scheme: light;
		--bg-primary: #fafafa;
		--bg-secondary: #f0f0f0;
		--card-bg: #ffffff;
		--text-primary: #111111;
		--text-secondary: #666666;
		--border-color: #e5e5e5;
		--accent: #2563eb;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background: var(--bg-primary);
		color: var(--text-primary);
	}

	h2 {
		font-size: 1.1rem;
		font-weight: 600;
		margin: 0 0 0.5rem;
		letter-spacing: -0.01em;
	}

	h3 {
		font-size: 1rem;
		font-weight: 600;
		margin: 0 0 0.25rem;
	}

	ul {
		margin: 0.25rem 0;
	}

	li {
		font-size: 0.9rem;
		line-height: 1.6;
	}

	.theme-toggle-btn:hover {
		background: var(--bg-secondary) !important;
		transition: background 0.2s ease;
	}

	.theme-dropdown-option:hover {
		background: var(--bg-secondary) !important;
		color: var(--text-primary) !important;
	}

	.theme-dropdown-option.active {
		background: var(--text-primary) !important;
		color: var(--bg-primary) !important;
	}
</style>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	const yearElement = document.getElementById('year');
	if (yearElement) {
		yearElement.textContent = new Date().getFullYear().toString();
	}

	gsap.registerPlugin(ScrollTrigger);

	const refreshScrollTrigger = () => {
		ScrollTrigger.refresh();
	};

	document.addEventListener("astro:page-load", refreshScrollTrigger);
	document.addEventListener("astro:after-swap", refreshScrollTrigger);
</script>
