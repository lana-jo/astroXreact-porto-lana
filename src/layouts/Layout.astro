---
import { ViewTransitions } from 'astro:transitions';
// import Navbar from "../components/Navbar";
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Portofolio Pribadi',
	description = 'Web portofolio modern dengan animasi'
} = Astro.props;
---
<!doctype html>
<html lang="id">
<head>
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta charset="UTF-8" />
    <meta property="og:image"
    content="img.png">
    <meta property="og:image:type" content="image/png">
	<meta name="viewport" content="width=device-width" />
	<link rel="icon" type="image/svg+xml" href="/profile.svg" />
	<link rel="icon" href="/lana.svg" />
	<meta name="generator" content={Astro.generator} />
	<meta name="description" content={description} />
	<title>{title}</title>
</head>
<body><!--
<div class="container">
	<section id="home" data-theme="dark">...</section>
	<section id="about" data-theme="light">...</section>
	<section id="projects" data-theme="dark">...</section>
	<section id="github" data-theme="light">...</section>
	<section id="contact" data-theme="dark">...</section>
</div> -->

<div class="bg-blur bg-blur-one"></div>
<div class="bg-blur bg-blur-two"></div>

<slot />
<ViewTransitions />
</body>
 <footer class="footer">
        <div class="footer-content">
            <p class="footer-copyright">&copy; <span id="year"></span> Lana Jauhar. All rights reserved.</p>
            <div class="footer-social">
                <a href="https://github.com/lana-jo" target="_blank" rel="noopener" class="social-icon-btn" title="GitHub">
                    <img src="/github.svg" alt="GitHub"/>
                </a>
                <a href="https://www.linkedin.com/in/lana-jauhar-75604317a/" target="_blank" rel="noopener" class="social-icon-btn" title="LinkedIn">
                    <img src="/linkedin.svg" alt="LinkedIn"/>
                </a>
                <a href="https://t.me/j0_here" target="_blank" rel="noopener" class="social-icon-btn" title="Telegram">
                    <img src="/telegram.svg" alt="Telegram"/>
                </a>
                <a href="mailto:lanajauhar06@gmail.com" class="social-icon-btn" title="Email Me">
                    <img src="/mail.svg" alt="Email"/>
                </a>
            </div>
        </div>
    </footer>
</html>

<style>
	:root {
		font-family: 'Inter', 'Segoe UI', Roboto, system-ui, -apple-system, sans-serif;
		color-scheme: dark;
		
		/* Light theme variables */
		--bg-primary: #ffffff;
		--bg-secondary: #f8fafc;
		--card-bg: #ffffff;
		--text-primary: #0f172a;
		--text-secondary: #475569;
		--border-color: #e2e8f0;
		--accent: #3b82f6;
	}

	/* Dark theme */
	[data-theme="dark"] {
		--bg-primary: #070b16;
		--bg-secondary: #0f172a;
		--card-bg: #1e293b;
		--text-primary: #e8eeff;
		--text-secondary: #94a3b8;
		--border-color: #334155;
		--accent: #60a5fa;
	}

	/* Light theme */
	[data-theme="light"] {
		--bg-primary: #ffffff;
		--bg-secondary: #f8fafc;
		--card-bg: #ffffff;
		--text-primary: #0f172a;
		--text-secondary: #475569;
		--border-color: #e2e8f0;
		--accent: #3b82f6;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background: var(--bg-primary);
		color: var(--text-primary);
		transition: background-color 0.3s ease, color 0.3s ease;
	}

	/* Theme dropdown styles */
	.theme-toggle-btn:hover {
		background: var(--bg-secondary) !important;
		transform: scale(1.05);
		transition: all 0.2s ease;
	}

	.theme-dropdown-option:hover {
		background: var(--bg-secondary) !important;
		color: var(--text-primary) !important;
	}

	.theme-dropdown-option.active {
		background: var(--accent) !important;
		color: white !important;
	}

	/* Smooth transitions for theme changes */
	* {
		transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
	}
</style>
<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

    const yearElement = document.getElementById('year');
    if (yearElement) {
        yearElement.textContent = new Date().getFullYear().toString();
    }


	// Register once
	gsap.registerPlugin(ScrollTrigger);

	// Fix ScrollTrigger after Astro View Transitions
	const refreshScrollTrigger = () => {
		ScrollTrigger.refresh();
	};

	document.addEventListener("astro:page-load", refreshScrollTrigger);
	document.addEventListener("astro:after-swap", refreshScrollTrigger);
</script>